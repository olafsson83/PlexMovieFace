# Copy this file to .env and fill in your own values. .env is gitignored.

# Full local path to the movie file you want to process.
MOVIE_PATH=C:\Media\Movies\Some Movie (2020)\Some Movie.mkv

# Where things land (relative to repo root).
DISCOVERY_FRAMES_DIR=discovery_frames
CHARACTERS_DIR=characters
SOURCE_FACES_DIR=source_faces
OUTPUT_DIR=output

# How often (seconds) to sample frames while discovering characters. Lower
# catches shorter appearances but takes longer; 2.0 is a good default.
DISCOVERY_INTERVAL_SEC=2.0

# Face clustering sensitivity. Lower eps = stricter (more, smaller clusters);
# a real actor getting split into two numbers is easy to fix (just supply the
# same source photo for both numbers), so this is intentionally conservative.
CLUSTER_EPS=0.4
CLUSTER_MIN_SAMPLES=3

# Cosine similarity floor for classifying an in-movie face as a known
# character during the swap stage. Deliberately higher/stricter than
# clustering (1.0 - CLUSTER_EPS) -- a wrong classification here means
# pasting the wrong character's face onto an unrelated person, which (unlike
# a clustering false-split) has no easy fix. Raise if you see a wrong face
# swapped onto someone; lower if genuine matches are being missed.
MATCH_THRESHOLD=0.7
# Lower floor applied to a face track that has already been confidently
# accepted -- keeps a real continuous shot from flickering the swap on/off
# when its noisier per-frame score dips below MATCH_THRESHOLD for an
# instant. Raise toward MATCH_THRESHOLD if a wrong face lingers instead of
# self-correcting; lower if genuine shots still flicker.
MAINTAIN_THRESHOLD=0.6

# Track-based identity decisions. When discovery has written calibration
# stats into clusters.json (automatic for new discoveries; run
# `python src/calibrate_clusters.py` to backfill older ones), enter/keep
# thresholds are derived per movie from its own score distributions and the
# two values above become the fallback. Precedence: explicitly setting
# MATCH_THRESHOLD or MAINTAIN_THRESHOLD in this file always wins (operator
# intent beats statistics -- calibration can misjudge a movie's extremes);
# set this false to disable calibration even without explicit thresholds.
IDENTITY_AUTO_CALIBRATION=true
# Required lead over the best OTHER identity before a track can acquire one
# (duplicate numbers mapped to the same source photo don't count as rivals).
MIN_MARGIN=0.08
# Scores this far above the enter threshold activate instantly; anything
# between enter and this needs CONFIRM_FRAMES consecutive confirming
# detections first -- a one-frame borderline false positive never confirms.
STRONG_ENTER_MARGIN=0.12
CONFIRM_FRAMES=3
# Consecutive below-keep detections before an accepted identity is dropped.
REJECT_FRAMES=4
# Detection passes a track survives without being matched to any face.
TRACK_MISS_LIMIT=2

# Plate matching: degrade the generated face layer to match the plate's
# optics before compositing (see plate_matching.py). Sharpness matching
# blurs the swap only when it's measurably sharper than the original face
# region -- a safety net against a too-crisp swap on defocused/soft plates.
SHARPNESS_MATCHING=true
SHARPNESS_TOLERANCE=0.12
SHARPNESS_MAX_SIGMA=3.0
SHARPNESS_TEMPORAL_SMOOTHING=0.7
# Grain matching adds the plate's noise texture to the swapped face (the
# swap output is missing it -- the main "pasted-on" tell on grainy or
# compressed footage). Only the measured deficit is added, so clean plates
# and already-noisy swaps are left alone.
GRAIN_MATCHING=true
GRAIN_MAX_SIGMA=12.0
GRAIN_MIN_SIGMA=0.5
GRAIN_TEMPORAL_SMOOTHING=0.7
GRAIN_EDGE_REJECT_PERCENTILE=75
# Motion blur matches the plate's exposure smear on moving faces (the swap
# is synthesized sharp even mid-movement). Conservative by design: damped
# on rotation, disabled on unreliable tracking, hard length cap.
MOTION_BLUR_MATCHING=true
MOTION_MIN_DISPLACEMENT_PX=0.75
MOTION_SHUTTER_FRACTION=0.5
MOTION_MAX_CROP_FRACTION=0.08
MOTION_TEMPORAL_SMOOTHING=0.65
MOTION_MIN_INLIER_RATIO=0.7
MOTION_ROTATION_LIMIT_DEG=3.0

# Adaptive low-light detection: on dark frames where the normal pass finds
# nothing (or loses a tracked face), retry detection on an analysis-only
# brightened copy at a larger detector canvas. Output pixels are never
# touched -- enhancement exists only so the detector can see.
ADAPTIVE_DETECTION=true
ADAPTIVE_DARK_LUMA=60
ADAPTIVE_RETRY_DET_SIZE=960
ADAPTIVE_GAMMA_MAX=2.2

# Refuse to swap frames past this head yaw instead of rendering a broken
# five-point profile warp (the track keeps its identity; the swap resumes
# instantly when the head turns back). Set POSE_GATE=false to disable.
POSE_GATE=true
MAX_ABS_YAW=65
POSE_EXIT_MARGIN=8

# Swap backend. "inswapper" (default, fast baseline) or "inswapper_gfpgan"
# (chains GFPGAN face restoration at 512px -- measurably more facial detail
# at a small identity-similarity cost and ~60% more render time; needs
# gfpgan_1.4.onnx from huggingface.co/facefusion/models-3.0.0 in
# ~/.insightface/models/). GFPGAN_BLEND trades detail vs identity:
# 0.8 = +53% detail / -0.05 identity, 0.5 = +12% / -0.02 (measured).
SWAP_BACKEND=inswapper
GFPGAN_BLEND=0.8

# insightface device index: 0 = first GPU, -1 = CPU only.
CTX_ID=0

# Run full face detection every Nth frame during the swap stage; frames in
# between track the same faces via optical flow instead (the main speedup).
DETECT_EVERY_N_FRAMES=5
# Mean grayscale pixel difference between consecutive frames above this
# forces a full re-detection immediately (a scene cut invalidates tracking).
SCENE_CUT_THRESHOLD=30.0
# Swap output is encoded in chunks of this many frames so an interrupted
# run can resume from the last complete chunk instead of starting over.
SEGMENT_FRAME_COUNT=5000

# Optional: only needed if you use setup.py's "look up movie via Plex" helper
# to fill in MOVIE_PATH instead of typing it yourself. Not used by the actual
# discovery/swap pipeline once MOVIE_PATH is set.
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=
